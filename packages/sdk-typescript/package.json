{
  "name": "@bimpeai/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the BimpeAI Agent Console API",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "node scripts/sync-version.mjs && tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:live": "BIMPEAI_LIVE=1 vitest run tests/live",
    "lint": "biome check src tests"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^2.1.4",
    "msw": "^2.6.0",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vitest": "^2.1.4"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BimpeAI/bimpe-sdk.git",
    "directory": "packages/sdk-typescript"
  },
  "keywords": [
    "bimpeai",
    "sdk",
    "agents",
    "ai",
    "typescript"
  ]
}
